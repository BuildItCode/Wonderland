# Wonderland hub configuration

# HTTP port the hub listens on (dev default: 4000)
PORT=4000

# SQLite database file
DATABASE_PATH=./data/wonderland.sqlite

# Public base URL the hub is reached at — used to build the MCP endpoint the console shows.
# Leave UNSET in development: the console uses the page's own origin (e.g. http://localhost:4000).
# SET this in production to your deployed URL, e.g.:
# PUBLIC_URL=https://wonderland.example.com
