{
  "name": "wonderland",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "author": "Nick Psarakis",
  "license":"MIT",
  "description": "Model-less MCP coordination hub where agents negotiate cross-codebase tasks.",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node --env-file-if-exists=.env dist/index.js",
    "build": "tsc && node copy-public.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "express": "5.2.1",
    "nanoid": "5.1.11",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/node": "25.9.2",
    "eslint": "10.4.1",
    "prettier": "3.8.3",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.1",
    "vitest": "4.1.8"
  }
}
